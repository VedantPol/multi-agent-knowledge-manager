APP_NAME="Multi-Agent Knowledge Management"
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=/data

# Optional. Without this key the app still runs with deterministic extractive answers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini

# Guardrail tuning
MAX_UPLOAD_CHARS=120000
MIN_CITATION_SCORE=0.02
